set interfaces ethernet eth2 address 10.0.2.6/30

set interfaces ethernet eth3 vif 10 description 'STATEFUL_SERVERS'
set interfaces ethernet eth3 vif 10 address 10.10.20.1/24

set protocols bgp system-as 65102
set protocols bgp parameters router-id 10.255.0.12
set protocols bgp parameters default multipath

set protocols bgp neighbor 10.0.1.5 remote-as 65001
set protocols bgp neighbor 10.0.1.5 description 'SPINE1'
set protocols bgp neighbor 10.0.1.5 address-family ipv4-unicast

set protocols bgp neighbor 10.0.2.5 remote-as 65001
set protocols bgp neighbor 10.0.2.5 description 'SPINE2'
set protocols bgp neighbor 10.0.2.5 address-family ipv4-unicast

set protocols bgp address-family ipv4-unicast network 10.255.0.12/32
set protocols bgp address-family ipv4-unicast network 10.10.20.0/24
commit
save
SCRIPT

