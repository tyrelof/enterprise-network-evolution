# -*- mode: ruby -*-
# vi: set ft=ruby :

VAGRANTFILE_API_VERSION = "2"

# =================================================================
# VyOS Provisioning Scripts
# =================================================================

$script_spine1 = <<-SCRIPT
#!/bin/vbash
source /opt/vyatta/etc/functions/script-template
configure
set interfaces loopback lo address 10.255.0.1/32
set interfaces ethernet eth1 description 'TO_LEAF1'
set interfaces ethernet eth1 address 10.0.1.1/30
set interfaces ethernet eth2 description 'TO_LEAF2'
set interfaces ethernet eth2 address 10.0.1.5/30
set interfaces ethernet eth3 description 'TO_LEAF3'
set interfaces ethernet eth3 address 10.0.1.9/30
set interfaces ethernet eth4 description 'TO_LEAF4'
set interfaces ethernet eth4 address 10.0.1.13/30

set protocols bgp system-as 65001
set protocols bgp parameters router-id 10.255.0.1
set protocols bgp parameters default multipath

set protocols bgp neighbor 10.0.1.2 remote-as 65101
set protocols bgp neighbor 10.0.1.2 description 'LEAF1'
set protocols bgp neighbor 10.0.1.2 address-family ipv4-unicast

set protocols bgp neighbor 10.0.1.6 remote-as 65102
set protocols bgp neighbor 10.0.1.6 description 'LEAF2'
set protocols bgp neighbor 10.0.1.6 address-family ipv4-unicast

set protocols bgp neighbor 10.0.1.10 remote-as 65103
set protocols bgp neighbor 10.0.1.10 description 'LEAF3'
set protocols bgp neighbor 10.0.1.10 address-family ipv4-unicast

set protocols bgp neighbor 10.0.1.14 remote-as 65104
set protocols bgp neighbor 10.0.1.14 description 'LEAF4'
set protocols bgp neighbor 10.0.1.14 address-family ipv4-unicast

set protocols bgp address-family ipv4-unicast network 10.255.0.1/32
commit
save
SCRIPT

